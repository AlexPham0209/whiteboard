# Environment variables for development and production
NODE_ENV=development

# Reverse Proxy Configurations
NGINX_PORT=

# Backend and frontend configuration
BACKEND_URL=
BACKEND_PORT=
FRONTEND_PORT=

# Replicas
FRONTEND_REPLICAS=
BACKEND_REPLICAS=

# Database configuration
POSTGRES_HOST=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=

# Cors configuration
CORS_ORIGINS=

# JWT and security configuration
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=
JWT_REFRESH_EXPIRATION=
SALT_ROUNDS=

# Dockerhub Credentials
DOCKERHUB_USERNAME=